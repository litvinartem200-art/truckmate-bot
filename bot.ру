import os, logging, aiohttp, re, asyncio
from telegram import Update, InlineKeyboardButton, InlineKeyboardMarkup
from telegram.ext import (
    Application, CommandHandler, CallbackQueryHandler,
    MessageHandler, filters, ContextTypes
)

logging.basicConfig(
    format="%(asctime)s — %(name)s — %(levelname)s — %(message)s",
    level=logging.INFO
)
logger = logging.getLogger(__name__)

# --- ПЕРЕМЕННЫЕ ОКРУЖЕНИЯ ---
TOKEN   = os.environ.get("BOT_TOKEN", "")
OCR_KEY = os.environ.get("OCR_KEY", "")
ORS_KEY = os.environ.get("ORS_API_KEY", "")

# --- СПРАВОЧНИКИ ---
DIESEL = {
    "FR":1.65,"DE":1.71,"IT":1.95,"CH":1.89,"ES":1.55,"BE":1.68,
    "NL":2.05,"AT":1.68,"PL":1.41,"CZ":1.52,"SK":1.48,"HU":1.44,
    "RO":1.38,"BG":1.32,"UA":0.95,"LU":1.48,"SI":1.55,"HR":1.42,
    "RS":1.38,"BA":1.35,"AL":1.50,"MK":1.40,"ME":1.45,"GR":1.78,
}

# --- ХРАНИЛИЩЕ ---
udata = {}

def ud(uid):
    if uid not in udata:
        udata[uid] = {"lang": "ru", "step": "", "from": "", "to": "", "weight": 20.0}
    return udata[uid]

T = {
    "ru": {
        "welcome": "Привет! Я *GidTrack*! Выбери язык:",
        "menu": "Главное меню",
        "r_route": "Маршрут LKW",
        "r_fuel": "Цены на дизель",
        "r_back": "Назад",
        "ask_from": "Откуда едешь?",
        "ask_to": "Куда едешь?",
        "ask_w": "Вес грузовика:"
    }
}

async def start(update: Update, ctx: ContextTypes.DEFAULT_TYPE):
    uid = update.effective_user.id
    ud(uid)["step"] = ""
    await update.message.reply_text(T["ru"]["welcome"], reply_markup=InlineKeyboardMarkup([
        [InlineKeyboardButton("Русский", callback_data="lang_ru")]
    ]))

async def btn(update: Update, ctx: ContextTypes.DEFAULT_TYPE):
    q = update.callback_query
    await q.answer()
    uid = q.from_user.id
    if q.data == "lang_ru":
        await q.edit_message_text(T["ru"]["menu"], reply_markup=InlineKeyboardMarkup([
            [InlineKeyboardButton(T["ru"]["r_route"], callback_data="m_route")]
        ]))
    elif q.data == "m_route":
        ud(uid)["step"] = "from"
        await q.edit_message_text(T["ru"]["ask_from"])

async def message_handler(update: Update, ctx: ContextTypes.DEFAULT_TYPE):
    uid = update.effective_user.id
    u = ud(uid)
    if u["step"] == "from":
        u["from"] = update.message.text
        u["step"] = "to"
        await update.message.reply_text(T["ru"]["ask_to"])
    elif u["step"] == "to":
        u["to"] = update.message.text
        u["step"] = ""
        await update.message.reply_text(f"Маршрут {u['from']} -> {u['to']} принят!")

def main():
    if not TOKEN: return
    app = Application.builder().token(TOKEN).build()
    app.add_handler(CommandHandler("start", start))
    app.add_handler(CallbackQueryHandler(btn))
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, message_handler))
    app.run_polling()

if __name__ == "__main__":
    main()
        
